rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admins collection — only existing admins can write
    // Each doc ID is a Firebase Auth UID; doc must exist for admin access
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Products — public read; full write requires verified admin;
    // anyone (even unauthenticated) may decrement stock and toggle availability
    // so that the checkout transaction can atomically deduct inventory.
    match /products/{productId} {
      allow read: if true;
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      allow update: if (request.auth != null
          && exists(/databases/$(database)/documents/admins/$(request.auth.uid)))
        || (request.resource.data.keys().hasOnly(["stock", "isAvailable"])
          && request.resource.data.stock <= resource.data.stock);
      allow delete: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Orders — anyone can create and read; update/delete requires verified admin
    match /orders/{orderId} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Shipping rates — public read; write requires verified admin
    match /shippingRates/{rateId} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Reviews — public read and create; update/delete requires verified admin
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Store settings (currency etc.) — public read; write requires verified admin
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Sales archives metadata — only verified admin can read/write
    match /salesArchives/{archiveId} {
      allow read, write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
  }
}
